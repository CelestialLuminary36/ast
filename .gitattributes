# Normalize line endings so gofmt and other Linux-default tooling stays clean
# even when contributors commit from Windows.
*.go         text eol=lf
*.yaml       text eol=lf
*.yml        text eol=lf
*.md         text eol=lf
*.sh         text eol=lf
*.json       text eol=lf

# PowerShell scripts stay CRLF — that is the convention on Windows.
*.ps1        text eol=crlf

# Binaries / archives must never be munged.
*.png        binary
*.jpg        binary
*.pdf        binary
*.zip        binary
*.gz         binary
*.exe        binary
